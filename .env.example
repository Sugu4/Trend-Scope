# ─── TrendScope Konfiguration ───────────────────────────────
# Kopiere diese Datei nach .env und trage deine Werte ein.
# NIEMALS .env in Git committen!

# ── Datenbanken ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=trendscope

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=trends

POSTGRES_URI=postgresql+asyncpg://postgres:password@localhost:5432/trendscope

# ── Social Media API Keys ────────────────────────────────────
# Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=DEIN_CLIENT_ID
REDDIT_CLIENT_SECRET=DEIN_CLIENT_SECRET
REDDIT_USER_AGENT=TrendScope/1.0

# YouTube Data API v3 (https://console.cloud.google.com)
YOUTUBE_API_KEY=DEIN_API_KEY

# X / Twitter API v2 (https://developer.twitter.com)
TWITTER_BEARER_TOKEN=DEIN_BEARER_TOKEN

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Wie viele Posts pro Plattform pro Collection-Run?
COLLECT_LIMIT=100

# NLP: Sprachen für spaCy
NLP_LANGUAGES=de,en
