# ─── TrendScope Konfiguration ───────────────────────────────
# Kopiere diese Datei nach .env und trage deine Werte ein.
# NIEMALS .env in Git committen!

# ── Datenbanken ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=trendscope

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=trends

POSTGRES_URI=postgresql+asyncpg://postgres:password@localhost:5432/trendscope

# ── Social Media API Keys ────────────────────────────────────

# Reddit (optional — läuft auch ohne Key via RSS)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendScope/1.0

# YouTube Data API v3 (https://console.cloud.google.com)
YOUTUBE_API_KEY=DEIN_API_KEY

# X / Twitter API v2 (kostenpflichtig — optional)
TWITTER_BEARER_TOKEN=

# NewsAPI (kostenlos bis 100 Anfragen/Tag)
# Key beantragen: https://newsapi.org/register
NEWSAPI_KEY=

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
COLLECT_LIMIT=100
